{
  "name": "openarena-announcer",
  "description": "Arena FPS announcer voice lines from OpenArena",
  "version": "1.0.0",
  "license": "GPL-2.0",
  "credits": "OpenArena contributors (http://openarena.ws)",
  "category": "arena",
  "sounds": [
    "sounds/accuracy.ogg",
    "sounds/assist.ogg",
    "sounds/defense.ogg",
    "sounds/denied.ogg",
    "sounds/excellent.ogg",
    "sounds/fight.ogg",
    "sounds/gauntlet.ogg",
    "sounds/humiliation.ogg",
    "sounds/impressive.ogg",
    "sounds/one.ogg",
    "sounds/perfect.ogg",
    "sounds/prepare.ogg",
    "sounds/sudden_death.ogg",
    "sounds/takenlead.ogg",
    "sounds/three.ogg",
    "sounds/two.ogg",
    "sounds/voc_holyshit.ogg",
    "sounds/youwin.ogg"
  ],
  "events": {
    "done": [
      "sounds/excellent.ogg",
      "sounds/impressive.ogg",
      "sounds/accuracy.ogg",
      "sounds/assist.ogg"
    ],
    "permission": [
      "sounds/prepare.ogg",
      "sounds/fight.ogg",
      "sounds/defense.ogg"
    ],
    "complete": [
      "sounds/youwin.ogg",
      "sounds/perfect.ogg",
      "sounds/takenlead.ogg"
    ],
    "error": [
      "sounds/denied.ogg",
      "sounds/humiliation.ogg",
      "sounds/sudden_death.ogg"
    ],
    "blocked": [
      "sounds/voc_holyshit.ogg",
      "sounds/gauntlet.ogg"
    ]
  }
}
