  "category": "ocean",
  "sounds": [
    "sounds/ambient-shore.ogg",
    "sounds/bubble-1.ogg",
    "sounds/bubble-2.ogg",
    "sounds/bubbles-underwater.ogg",
    "sounds/coastal-ambient.ogg",
    "sounds/current.ogg",
    "sounds/deep-1.ogg",
    "sounds/deep-2.ogg",
    "sounds/shore-1.ogg",
    "sounds/shore-2.ogg",
    "sounds/splash-1.ogg",
    "sounds/splash-2.ogg",
    "sounds/splash-3.ogg",
    "sounds/splash-big.ogg",
    "sounds/splash.ogg",
    "sounds/tide-1.ogg",
    "sounds/tide-2.ogg",
    "sounds/wave-1.ogg",
    "sounds/wave-2.ogg",
    "sounds/wind-1.ogg",
    "sounds/wind-2.ogg"
  ],
  "events": {
    "done": [
      "sounds/ambient-shore.ogg",
      "sounds/bubble-1.ogg",
      "sounds/bubble-2.ogg",
      "sounds/bubbles-underwater.ogg",
      "sounds/coastal-ambient.ogg"
    ],
    "permission": [
      "sounds/current.ogg",
      "sounds/deep-1.ogg",
      "sounds/deep-2.ogg",
      "sounds/shore-1.ogg",
      "sounds/shore-2.ogg"
    ],
    "complete": [
      "sounds/splash-1.ogg",
      "sounds/splash-2.ogg",
      "sounds/splash-3.ogg",
      "sounds/splash-big.ogg",
      "sounds/splash.ogg"
    ],
    "error": [
      "sounds/tide-1.ogg",
      "sounds/tide-2.ogg",
      "sounds/wave-1.ogg",
      "sounds/wave-2.ogg",
      "sounds/wind-1.ogg"
    ],
    "blocked": [
      "sounds/wind-2.ogg"
    ]
  }
}
