{
  "name": "kenney-scifi",
  "description": "Futuristic sci-fi notification sounds by Kenney",
  "version": "1.0.0",
  "license": "CC0-1.0",
  "credits": "Kenney (https://kenney.nl)",
  "category": "sci-fi",
  "sounds": [
    "sounds/computer-1.ogg",
    "sounds/computer-2.ogg",
    "sounds/computer-3.ogg",
    "sounds/door-close.ogg",
    "sounds/door-open.ogg",
    "sounds/engine-1.ogg",
    "sounds/explosion-1.ogg",
    "sounds/explosion-2.ogg",
    "sounds/forcefield-1.ogg",
    "sounds/forcefield-2.ogg",
    "sounds/impact-1.ogg",
    "sounds/impact-2.ogg",
    "sounds/laser-large.ogg",
    "sounds/laser-retro.ogg",
    "sounds/low-explosion.ogg",
    "sounds/slime.ogg",
    "sounds/thruster-1.ogg",
    "sounds/thruster-2.ogg"
  ],
  "events": {
    "done": [
      "sounds/computer-1.ogg",
      "sounds/computer-2.ogg",
      "sounds/computer-3.ogg",
      "sounds/door-open.ogg"
    ],
    "permission": [
      "sounds/forcefield-1.ogg",
      "sounds/forcefield-2.ogg",
      "sounds/laser-retro.ogg"
    ],
    "complete": [
      "sounds/thruster-1.ogg",
      "sounds/thruster-2.ogg",
      "sounds/engine-1.ogg"
    ],
    "error": [
      "sounds/explosion-1.ogg",
      "sounds/explosion-2.ogg",
      "sounds/low-explosion.ogg",
      "sounds/impact-1.ogg",
      "sounds/impact-2.ogg"
    ],
    "blocked": [
      "sounds/door-close.ogg",
      "sounds/laser-large.ogg",
      "sounds/slime.ogg"
    ]
  }
}
