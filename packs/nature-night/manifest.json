    "sounds/night-call-1.ogg",
    "sounds/night-call-2.ogg",
    "sounds/night-cricket-1.ogg",
    "sounds/night-cricket-2.ogg",
    "sounds/night-owl.ogg",
    "sounds/rustle-1.ogg",
    "sounds/rustle-2.ogg",
    "sounds/rustle-3.ogg",
